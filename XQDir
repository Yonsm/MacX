#!/bin/sh
Pictures="$1"

# Check
if [ ! -d "$Pictures" ]; then
	echo "Pictures dir not exist"
	exit 1
fi
cd "$Pictures"


qren()
{
	for PIC in `ls "$1"|tr " " "?"`
	do
		PIC=`echo "$PIC"|tr "?" " "`
		PIC2=`echo "$PIC"|tr " " "_"`
		if [[ "$PIC" != "$PIC2" ]]; then
			mv -n "$1/$PIC" "$1/$PIC2"
		fi
	done
}

qmove()
{
	for PIC in `ls "$1"|tr " " "?"`
	do
		PIC=`echo "$PIC"|tr "?" " "`
		YEAR=${PIC%%"-"*}
		if [ $YEAR -ge 2000 ] 2>/dev/null && [ $YEAR -le 2009 ] 2>/dev/null; then
			QDIR=$YEAR
		elif [ $YEAR -ge 2010 ] 2>/dev/null && [ $YEAR -le 2022 ] 2>/dev/null; then
			MONTH=${PIC#*"-"}
			MONTH=${MONTH:0:2}
			if [ $MONTH -ge 1 ] 2>/dev/null && [ $MONTH -le 3 ] 2>/dev/null; then
				QDIR=$YEAR.Q1
			elif [ $MONTH -ge 4 ] 2>/dev/null && [ $MONTH -le 6 ] 2>/dev/null; then
				QDIR=$YEAR.Q2
			elif [ $MONTH -ge 7 ] 2>/dev/null && [ $MONTH -le 9 ] 2>/dev/null; then
				QDIR=$YEAR.Q3
			elif [ $MONTH -ge 10 ] 2>/dev/null && [ $MONTH -le 12 ] 2>/dev/null; then
				QDIR=$YEAR.Q4
			else
				echo "ERROR: Unexception month: $1/$PIC"
				continue
			fi
		else
			echo "ERROR: Unexception year: $1/$PIC"
			continue
		fi
		[ ! -d $QDIR ] && mkdir $QDIR
		PIC2=`echo "$PIC"|tr " " "_"`
		mv -n "$1/$PIC" "$QDIR/$PIC2"
	done
	rmdir "$1"
}
		
[ -d "2000.00 头像" ] && rm -rf "2000.00 头像"
[ -d "2016.04 装修" ] && rm -rf "2016.04 装修"

qdir()
{
	case "$1" in
		2000|2001|2002|2003|2004|2005|2006|2007|2008|2009|*.Q1|*.Q2|*.Q3|*.Q4)
			echo "RENAME: $1"
			qren "$1"
			;;
		20*)
			echo "MOVE: $1"
			qmove "$1"
			;;
		*)
			echo "SKIP: $1"
			;;
	esac
	return 0
}

[ ! -z "$2" ] && qren "$2" && exit

for DIR in `ls|tr " " "?"`
do
	echo "$DIR" >> /tmp/test.txt
	DIR=`echo "$DIR"|tr "?" " "`
	qdir "$DIR"
done

